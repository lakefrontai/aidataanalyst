# ─── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Mistral model ID on Bedrock (choose one):
#   mistral.mistral-small-2402-v1:0
#   mistral.mistral-7b-instruct-v0:2
#   mistral.mixtral-8x7b-instruct-v0:1
BEDROCK_MODEL_ID=mistral.mistral-small-2402-v1:0

# ─── Microsoft Fabric ──────────────────────────────────────────────────────────
# SQL Analytics Endpoint (found in Fabric workspace > SQL endpoint)
FABRIC_SERVER=your-workspace.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=your_database_name

# Auth option A – Service Principal
FABRIC_TENANT_ID=your_tenant_id
FABRIC_CLIENT_ID=your_client_id
FABRIC_CLIENT_SECRET=your_client_secret

# Auth option B – Username / Password (uncomment if not using SP)
# FABRIC_USERNAME=user@yourdomain.com
# FABRIC_PASSWORD=your_password

# ─── App settings ──────────────────────────────────────────────────────────────
MAX_ROWS_DISPLAY=50
MAX_SCHEMA_TABLES=100
