# Copy to /etc/mydatatalk/web.env on the EC2 instance (chmod 600, owned by
# the mydatatalk user). Referenced by mydatatalk-web.service.

NODE_ENV=production

# Native Postgres running on the same instance, bound to localhost only.
DATABASE_URL="postgresql://mydatatalk:CHANGE_ME@localhost:5432/mydatatalk"

# Session signing secret — generate with: openssl rand -base64 32
# Must stay the same across restarts/deploys or existing sessions break.
AUTH_SECRET="CHANGE_ME"
