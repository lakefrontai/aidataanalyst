# Copy to .env.local and fill in real values. Never commit .env.local.
# For production deployment (EC2 + native Postgres), see DEPLOY.md and
# deploy/web.env.example instead.

# Postgres connection string for the account database (register/login).
# Local dev: docker run -d -e POSTGRES_USER=mydatatalk -e POSTGRES_PASSWORD=devpass \
#   -e POSTGRES_DB=mydatatalk -p 5433:5432 postgres:16-alpine
DATABASE_URL="postgresql://mydatatalk:devpass@localhost:5433/mydatatalk"

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=""
